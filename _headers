# ════════════════════════════════════════════════════════════════════
# FAVICONS & ICONES — cache long terme (immutable)
# ════════════════════════════════════════════════════════════════════
# Force Chrome/Safari/Firefox à cacher les favicons 1 an au lieu de
# les redécharger à chaque visite (cause de la "disparition" entre rechargements).

/favicon.ico
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/x-icon

/favicon.png
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/png

/favicon-16x16.png
  Cache-Control: public, max-age=31536000, immutable
